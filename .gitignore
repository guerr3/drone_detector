# Data files
# Keep folder structure, ignore large local datasets
/data/raw/*
!/data/raw/.gitkeep
/data/processed/*
!/data/processed/.gitkeep
*.csv
*.tsv
*.parquet
*.h5
*.hdf5
*.npz
*.npy

# Models and checkpoints
/models/*
!/models/.gitkeep
*.ckpt
*.weights.h5
*.pt
*.pth
*.onnx

# TensorBoard logs
logs/
**/events.out.tfevents.*

# Kaggle artifacts
kaggle.json
*.zip

# Google Colab temporary files
/content/
